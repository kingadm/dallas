# Server
PORT=3001

# Database (Docker compose example)
DATABASE_URL="postgresql://cardapio:cardapio@localhost:5432/cardapio?schema=public"

# JWT
JWT_SECRET="troque_este_secret"
JWT_EXPIRES_IN="7d"

# Admin seed
ADMIN_EMAIL="admin@admin.com"
ADMIN_PASSWORD="admin123"

# CORS (separe por vírgula). Ex:
# CORS_ORIGINS="http://localhost:3000,https://seuapp.vercel.app"
CORS_ORIGINS="http://localhost:3000"

# Cloudinary
CLOUDINARY_CLOUD_NAME="xxxx"
CLOUDINARY_API_KEY="xxxx"
CLOUDINARY_API_SECRET="xxxx"